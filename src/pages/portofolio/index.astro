---
import Layout from '../../layouts/Layout.astro';
import manifest from '../../../data/manifest.json';

const projects = manifest.portfolio;
---

<Layout title="All Portfolio | Muhdan Fyan">
  <main class="container mx-auto px-6 pt-32 mb-20">
    <div class="mb-12">
      <h1 class="text-4xl font-extrabold mb-4">All Portfolio</h1>
      <p class="text-slate-600">Kumpulan proyek yang telah saya kerjakan.</p>
      <div class="w-12 h-1 bg-indigo-600 rounded-full mt-6"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => {
        const slug = project.slug || project.title.toLowerCase().replace(/\s+/g, '-');
        return (
          <div 
            onclick={`window.location.href='/portofolio/${slug}'`}
            class="project-card group cursor-pointer bg-white border border-slate-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all flex flex-col h-full" 
            data-langs={JSON.stringify(project.available_langs)}
          >
            <div class="relative overflow-hidden">
              <img src={(project.image && project.image.startsWith('http')) ? project.image : '/' + (project.image || 'img/screenshots/default.png')} alt={project.title} class="w-full h-48 object-cover group-hover:scale-105 transition-all duration-500" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-all"></div>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold project-title" data-id={project.title} data-en={project.title_en}>{project.title}</h3>
                <div class="flex flex-col items-end gap-1">
                  <span class="text-[10px] font-black px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded uppercase tracking-tighter">{project.project_type || project.category}</span>
                  <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded-full border ${
                    project.difficulty_level === 'Expert' ? 'bg-red-50 text-red-600 border-red-100' :
                    project.difficulty_level === 'Advanced' ? 'bg-orange-50 text-orange-600 border-orange-100' :
                    'bg-slate-50 text-slate-500 border-slate-100'
                  }`}>
                    {project.difficulty_level || 'Intermediate'}
                  </span>
                </div>
              </div>
              <p class="text-slate-600 text-sm mb-6 line-clamp-2 project-desc" data-id={project.description} data-en={project.description_en}>{project.description}</p>
              
              <div class="grid grid-cols-2 gap-3 mt-auto pt-4 border-t border-slate-50">
                <a 
                  href={project.url} 
                  target="_blank" 
                  onclick="event.stopPropagation()"
                  class="flex items-center justify-center gap-1.5 py-2 px-3 bg-indigo-50 text-indigo-600 rounded-xl text-xs font-bold hover:bg-indigo-600 hover:text-white transition-all"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  Visit App
                </a>
                  <a 
                    href={`https://wa.me/6283134086899?text=Halo Fyan, saya tertarik buat sistem seperti ${project.title}`}
                    target="_blank"
                    onclick="event.stopPropagation()"
                    class="flex items-center justify-center gap-1.5 py-2 px-3 bg-emerald-50 text-emerald-600 rounded-xl text-xs font-bold hover:bg-emerald-600 hover:text-white transition-all order-link"
                    data-id="Pesan Jasa"
                    data-en="Order Service"
                  >
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.98zm11.387-5.464c-.301-.15-1.779-.877-2.053-.976-.275-.1-.475-.15-.675.15-.199.301-.775.976-.951 1.176-.175.199-.35.225-.651.075-.301-.15-1.267-.467-2.414-1.49-.893-.797-1.495-1.782-1.671-2.081-.175-.301-.019-.463.131-.612.135-.133.301-.351.452-.526.149-.175.199-.301.299-.501.101-.199.051-.376-.025-.526-.075-.15-.675-1.628-.925-2.229-.244-.588-.491-.508-.675-.508-.174-.001-.374-.001-.574-.001-.2 0-.526.075-.802.376-.275.301-1.051 1.026-1.051 2.504 0 1.477 1.076 2.904 1.226 3.104.15.199 2.118 3.235 5.13 4.537.716.31 1.275.496 1.71.636.72.228 1.375.196 1.892.119.577-.085 1.779-.726 2.028-1.427.25-.701.25-1.302.175-1.427-.075-.125-.275-.199-.575-.35z"/></svg>
                    Pesan Jasa
                  </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </main>
</Layout>
