---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const projectsDir = path.join(process.cwd(), 'content/portfolio');
  const folders = fs.existsSync(projectsDir) ? fs.readdirSync(projectsDir) : [];
  
  return folders.map((slug) => {
    const filePath = path.join(projectsDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    
    const { data, content: full_description } = matter(fs.readFileSync(filePath, 'utf-8'));
    
    // Check for EN version
    const enPath = path.join(projectsDir, slug, 'index.en.mdoc');
    let full_description_en = null;
    if (fs.existsSync(enPath)) {
      const { content } = matter(fs.readFileSync(enPath, 'utf-8'));
      full_description_en = content;
    }

    const project = { 
      ...data, 
      full_description, 
      full_description_en,
      slug 
    };

    return {
      params: { slug },
      props: { project },
    };
  }).filter(Boolean);
}

const { project } = Astro.props;

// Fallback for projects without detailed info
const hasDetails = project.full_description?.trim() || project.full_description_en?.trim();
---

<Layout title={`${project.title} | Portfolio Detail`}>
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="logo font-black text-2xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
        MUHDAN FYAN
      </a>
      <div class="flex items-center gap-6">
        <a href="/portofolio" class="text-sm font-bold text-slate-600 hover:text-indigo-600">Back to Portfolio</a>
        <button id="langToggle" class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-sm font-bold hover:bg-indigo-600 hover:text-white transition-all">
          <span id="langLabel">ID</span>
        </button>
      </div>
    </div>
  </nav>

  <main class="pt-32 pb-20">
    <div class="container mx-auto px-6">
      <!-- Hero Section -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
        <div class="order-2 lg:order-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block px-4 py-1 bg-indigo-50 text-indigo-600 rounded-full text-sm font-semibold">
              {project.project_type || project.category}
            </span>
            <span class={`px-3 py-1 rounded-full text-xs font-bold border ${
              project.difficulty === 'Expert' ? 'bg-red-50 text-red-600 border-red-100' :
              project.difficulty === 'Advanced' ? 'bg-orange-50 text-orange-600 border-orange-100' :
              'bg-slate-50 text-slate-500 border-slate-100'
            }`}>
              {project.difficulty || 'Intermediate'}
            </span>
          </div>
          <h1 class="text-5xl font-extrabold mb-6 project-title" data-id={project.title} data-en={project.title_en || project.title}>
            {project.title}
          </h1>
          <p class="text-xl text-slate-600 mb-8 project-desc" data-id={project.description} data-en={project.description_en || project.description}>
            {project.description}
          </p>
          <div class="flex gap-4">
            <a href={project.link} target="_blank" class="bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:shadow-lg hover:shadow-indigo-200 transition-all lang-text" data-id="Kunjungi Situs" data-en="Visit Site">
              Kunjungi Situs
            </a>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-purple-500 blur-2xl opacity-10 rounded-3xl group-hover:opacity-20 transition-all"></div>
            <img 
              src={(project.image && project.image.startsWith('http')) ? project.image : '/' + (project.image || 'img/screenshots/default.png')} 
              alt={project.title} 
              class="w-full aspect-video object-cover rounded-3xl shadow-2xl relative z-10 border border-slate-100"
            />
          </div>
        </div>
      </div>

      <!-- Metrics & Highlights Grid -->
      <div class="grid lg:grid-cols-3 gap-8 mb-20">
        <!-- Lighthouse Metrics -->
        <div class="lg:col-span-2 bg-slate-900 rounded-[2rem] p-10 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 opacity-10">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg>
          </div>
          <h2 class="text-xl font-bold mb-8 flex items-center gap-2">
            <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
            Performance Metrics (Lighthouse)
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            {['performance', 'accessibility', 'best_practices', 'seo'].map((key) => {
              const score = project.metrics?.[key] || 0;
              const colorClass = score >= 90 ? 'text-emerald-400' : score >= 50 ? 'text-orange-400' : 'text-red-400';
              return (
                <div class="text-center">
                  <div class={`text-4xl font-black mb-2 ${colorClass}`}>{score}</div>
                  <div class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">
                    {key.replace('_', ' ')}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Key Highlights -->
        <div class="bg-indigo-600 rounded-[2rem] p-10 text-white shadow-xl shadow-indigo-200">
          <h2 class="text-xl font-bold mb-6 lang-text" data-id="Highlight Utama" data-en="Key Highlights">Highlight Utama</h2>
          <ul class="space-y-4">
            {(project.highlights || []).map((highlight, index) => (
              <li class="flex items-start gap-3 text-sm font-medium">
                <svg class="w-5 h-5 text-indigo-300 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="project-highlight" data-id={highlight} data-en={project.highlights_en?.[index]}>{highlight}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {hasDetails ? (
        <div class="max-w-4xl mx-auto">
          <!-- Full Description -->
          <section class="mb-16">
            <h2 class="text-2xl font-bold mb-6 lang-text" data-id="Tentang Proyek" data-en="About Project">Tentang Proyek</h2>
            <p class="text-slate-600 leading-relaxed project-full-desc" data-id={project.full_description} data-en={project.full_description_en}>
              {project.full_description}
            </p>
          </section>

          <!-- Tech Stack -->
          <section class="mb-16">
            <h2 class="text-2xl font-bold mb-6 lang-text" data-id="Teknologi" data-en="Technology">Teknologi</h2>
            <div class="flex flex-wrap gap-3 mb-6">
              {project.tech_stack?.map((tech) => (
                <span class="px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-slate-600 font-bold text-sm">
                  {tech}
                </span>
              ))}
            </div>
            {project.tech_rationale && (
              <div class="mt-8 p-6 bg-slate-50 border-l-4 border-indigo-600 rounded-r-2xl">
                <h3 class="text-xs font-black uppercase tracking-widest text-indigo-600 mb-2 lang-text" data-id="Rasionalitas Teknologi" data-en="Tech Rationale">
                  Rasionalitas Teknologi
                </h3>
                <p class="text-slate-600 text-sm leading-relaxed project-tech-rationale" data-id={project.tech_rationale} data-en={project.tech_rationale_en}>
                  {project.tech_rationale}
                </p>
              </div>
            )}
          </section>

          <div class="grid md:grid-cols-2 gap-12">
            <!-- Impact -->
            <section>
              <div class="p-8 bg-indigo-50/50 rounded-3xl border border-indigo-100">
                <h2 class="text-xl font-bold mb-4 text-indigo-600 lang-text" data-id="Impak & Hasil" data-en="Impact & Results">Impak & Hasil</h2>
                <p class="text-slate-700 text-sm leading-relaxed project-impact" data-id={project.impact} data-en={project.impact_en}>
                  {project.impact}
                </p>
              </div>
            </section>

            <!-- Process -->
            <section>
              <div class="p-8 bg-purple-50/50 rounded-3xl border border-purple-100">
                <h2 class="text-xl font-bold mb-4 text-purple-600 lang-text" data-id="Proses Pengerjaan" data-en="Development Process">Proses Pengerjaan</h2>
                <p class="text-slate-700 text-sm leading-relaxed project-process" data-id={project.process} data-en={project.process_en}>
                  {project.process}
                </p>
              </div>
            </section>
          </div>
        </div>
      ) : (
        <div class="text-center py-20 bg-slate-50 rounded-3xl border border-slate-100 mb-20">
          <p class="text-slate-500 font-medium lang-text" data-id="Detail lengkap untuk proyek ini sedang dalam penyusunan." data-en="Full details for this project are currently being compiled.">
            Detail lengkap untuk proyek ini sedang dalam penyusunan.
          </p>
        </div>
      )}

      <!-- Call to Action Section -->
      <section class="mt-20">
        <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-[2.5rem] p-12 text-center text-white shadow-2xl shadow-indigo-200">
          <h2 class="text-3xl md:text-4xl font-extrabold mb-4 lang-text" data-id="Tertarik Membangun Proyek Seperti Ini?" data-en="Interested in Building a Project Like This?">
            Tertarik Membangun Proyek Seperti Ini?
          </h2>
          <p class="text-indigo-100 text-lg mb-10 max-w-2xl mx-auto lang-text" data-id="Mari berdiskusi bagaimana saya bisa membantu mewujudkan solusi digital yang berdampak untuk bisnis atau ide Anda." data-en="Let's discuss how I can help bring high-impact digital solutions to life for your business or ideas.">
            Mari berdiskusi bagaimana saya bisa membantu mewujudkan solusi digital yang berdampak untuk bisnis atau ide Anda.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://wa.me/6283134086899" target="_blank" class="bg-white text-indigo-600 px-10 py-4 rounded-2xl font-bold hover:bg-indigo-50 transition-all flex items-center justify-center gap-2">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.98zm11.387-5.464c-.301-.15-1.779-.877-2.053-.976-.275-.1-.475-.15-.675.15-.199.301-.775.976-.951 1.176-.175.199-.35.225-.651.075-.301-.15-1.267-.467-2.414-1.49-.893-.797-1.495-1.782-1.671-2.081-.175-.301-.019-.463.131-.612.135-.133.301-.351.452-.526.149-.175.199-.301.299-.501.101-.199.051-.376-.025-.526-.075-.15-.675-1.628-.925-2.229-.244-.588-.491-.508-.675-.508-.174-.001-.374-.001-.574-.001-.2 0-.526.075-.802.376-.275.301-1.051 1.026-1.051 2.504 0 1.477 1.076 2.904 1.226 3.104.15.199 2.118 3.235 5.13 4.537.716.31 1.275.496 1.71.636.72.228 1.375.196 1.892.119.577-.085 1.779-.726 2.028-1.427.25-.701.25-1.302.175-1.427-.075-.125-.275-.199-.575-.35z"/></svg>
              Chat via WhatsApp
            </a>
            <a href="mailto:muhdanfyan@gmail.com" class="bg-indigo-500/20 text-white border border-indigo-400/30 px-10 py-4 rounded-2xl font-bold hover:bg-indigo-500/30 transition-all lang-text" data-id="Kirim Email" data-en="Send Email">
              Kirim Email
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <footer class="border-t border-slate-100 py-12">
    <div class="container mx-auto px-6 text-center">
      <p class="text-slate-400 text-sm font-medium">
        &copy; 2026 Muhdan Fyan Syah Sofian.
      </p>
    </div>
  </footer>

  <script is:inline>
    let currentLang = localStorage.getItem('lang') || 'id';

    function updateLanguageUI() {
      document.getElementById('langLabel').innerText = currentLang.toUpperCase();
      
      document.querySelectorAll('.lang-text').forEach(el => {
        el.innerText = currentLang === 'en' ? el.dataset.en : el.dataset.id;
      });

      const titleEl = document.querySelector('.project-title');
      const descEl = document.querySelector('.project-desc');
      const fullDescEl = document.querySelector('.project-full-desc');
      const techRationaleEl = document.querySelector('.project-tech-rationale');
      const impactEl = document.querySelector('.project-impact');
      const processEl = document.querySelector('.project-process');

      if (titleEl) titleEl.innerText = currentLang === 'en' ? titleEl.dataset.en : titleEl.dataset.id;
      if (descEl) descEl.innerText = currentLang === 'en' ? descEl.dataset.en : descEl.dataset.id;
      if (fullDescEl) fullDescEl.innerText = currentLang === 'en' ? fullDescEl.dataset.en : fullDescEl.dataset.id;
      if (techRationaleEl) techRationaleEl.innerText = currentLang === 'en' ? techRationaleEl.dataset.en : techRationaleEl.dataset.id;
      if (impactEl) impactEl.innerText = currentLang === 'en' ? impactEl.dataset.en : impactEl.dataset.id;
      if (processEl) processEl.innerText = currentLang === 'en' ? processEl.dataset.en : processEl.dataset.id;

      document.querySelectorAll('.project-highlight').forEach(el => {
        el.innerText = currentLang === 'en' ? el.dataset.en : el.dataset.id;
      });
    }

    document.getElementById('langToggle').addEventListener('click', () => {
      currentLang = currentLang === 'id' ? 'en' : 'id';
      localStorage.setItem('lang', currentLang);
      updateLanguageUI();
    });

    updateLanguageUI();
  </script>
</Layout>
