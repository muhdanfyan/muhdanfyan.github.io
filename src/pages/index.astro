              <span class="lang-text" data-id="Lihat Materi" data-en="View Materials">Lihat Materi</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/teach/" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:gap-4 transition-all lang-text"
           data-id="Lihat Semua Pengalaman" data-en="View All Teaching">
          Lihat Semua Pengalaman <span class="text-xl">→</span>
        </a>
      </div>
    </section>

	</main>

  <script is:inline>
    function updateIndexUI() {
      const currentLang = localStorage.getItem('lang') || 'id';
      
      // Update Projects Visibility & Text
      document.querySelectorAll('.project-card').forEach(card => {
        if (card instanceof HTMLElement) {
          const langs = JSON.parse(card.dataset.langs || '["id", "en"]');
          card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
        }
      });

      // Update Writings Visibility & Text
      document.querySelectorAll('.writing-card').forEach(card => {
        if (card instanceof HTMLElement) {
          const langs = JSON.parse(card.dataset.langs || '["id", "en"]');
          card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
        }
      });
    }

    function initIndex() {
      // Auto-Language Detection for First Time Visitors
      if (!localStorage.getItem('lang')) {
        try {
          const userLang = navigator.language || '';
          const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
          const isIndonesianTZ = timezone.includes('Jakarta') || timezone.includes('Makassar') || timezone.includes('Jayapura') || timezone.includes('Pontianak');
          const isIndonesianLang = userLang.toLowerCase().startsWith('id');
          localStorage.setItem('lang', (isIndonesianTZ || isIndonesianLang) ? 'id' : 'en');
        } catch (e) {
          localStorage.setItem('lang', 'id');
        }
      }
      updateIndexUI();
      // Listen for language changes from Layout's langToggle
      const langToggle = document.getElementById('langToggle');
      if (langToggle) {
        langToggle.addEventListener('click', () => {
          setTimeout(updateIndexUI, 50); // slight delay to ensure localStorage is updated
        });
      }
    }

    initIndex();
    document.addEventListener('astro:page-load', initIndex);
  </script>
</Layout>
