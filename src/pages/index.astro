---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';
import manifest from '../../data/manifest.json';

const projects = manifest.portfolio;

const tulisanDir = path.join(process.cwd(), 'tulisan');
const folders = fs.existsSync(tulisanDir) ? fs.readdirSync(tulisanDir) : [];

const writings = folders
  .map((slug) => {
    const filePath = path.join(tulisanDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    const fileContent = fs.readFileSync(filePath, 'utf-8');
    const { data } = matter(fileContent);
    return {
      slug,
      title: data.title_id || slug,
      title_en: data.title_en || slug,
      date: data.date || '',
      category: data.category || 'General',
      description: data.description_id || '',
      description_en: data.description_en || '',
      image: data.image || '',
      available_langs: data.content_en_markdown ? ['id', 'en'] : ['id']
    };
  })
  .filter(Boolean)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
