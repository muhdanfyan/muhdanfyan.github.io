            ))}
          </div>
        </div>

        <!-- Education Column -->
        <div>
          <div class="mb-12">
            <h2 class="text-3xl font-bold mb-2 lang-text" data-id="Pendidikan" data-en="Education">Pendidikan</h2>
            <div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
          </div>

          <div class="space-y-8">
            {education.map((edu) => (
