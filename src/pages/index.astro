                <span class="text-xs font-bold text-indigo-600 uppercase tracking-wider lang-text" data-id={edu.period} data-en={edu.period_en}>{edu.period}</span>
                <h3 class="text-xl font-bold mt-1 lang-text" data-id={edu.degree} data-en={edu.degree_en}>{edu.degree}</h3>
                <p class="text-slate-500 font-medium mb-2">{edu.school}</p>
