---
import Layout from '../layouts/Layout.astro';
import manifest from '../../data/manifest.json';

const projects = manifest.portfolio;
const writings = manifest.writing.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Muhdan Fyan | Full Stack Developer">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <div class="logo font-black text-2xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
        MUHDAN FYAN
      </div>
      <div class="flex items-center gap-6">
        <a href="#portfolio" class="text-sm font-bold text-slate-600 hover:text-indigo-600">Portfolio</a>
        <a href="#writing" class="text-sm font-bold text-slate-600 hover:text-indigo-600">Writing</a>
        <button id="langToggle" class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-sm font-bold hover:bg-indigo-600 hover:text-white transition-all">
          <span id="langLabel">ID</span>
        </button>
      </div>
    </div>
  </nav>

	<main class="container mx-auto px-6 pt-32">
		<!-- Hero Section -->
		<section class="flex flex-col items-center text-center gap-10 mb-20">
			<div class="relative">
				<div class="absolute inset-0 bg-gradient-to-r from-indigo-500 to-purple-500 blur-3xl opacity-20 rounded-full animate-pulse"></div>
				<img 
					src="https://res.cloudinary.com/duntlhjil/image/upload/v1765759801/pisantri/fotosantri/xcbhj9tffpopikh0mvrv.jpg" 
					class="w-40 h-40 rounded-full border-4 border-white shadow-2xl relative z-10"
					alt="Muhdan Fyan"
				/>
			</div>
			
			<div>
				<span class="inline-block px-4 py-1 bg-indigo-50 text-indigo-600 rounded-full text-sm font-semibold mb-4">
					Full Stack Developer
				</span>
				<h1 class="text-6xl font-extrabold mb-6 tracking-tight text-slate-900">
					Muhdan Fyan
				</h1>
				<p class="text-xl text-slate-600 max-w-2xl mx-auto mb-8">
					Membangun solusi digital yang efisien, teruji, dan berdampak nyata bagi ekosistem teknologi di Indonesia.
				</p>
				<div class="flex gap-4 justify-center">
					<a href="#portfolio" class="bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:shadow-lg hover:shadow-indigo-200 transition-all">
						Lihat Portofolio
					</a>
					<a href="https://github.com/muhdanfyan" target="_blank" class="border border-slate-200 px-8 py-3 rounded-xl font-bold hover:bg-slate-50 transition-all">
						GitHub
					</a>
				</div>
			</div>
		</section>

    <!-- Experience & Education Section -->
    <section id="resume" class="mb-20">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Experience Column -->
        <div>
          <div class="mb-12">
            <h2 class="text-3xl font-bold mb-2">Professional Experience</h2>
            <div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
          </div>
          
          <div class="space-y-8">
            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-indigo-600 uppercase tracking-wider">April 2026</span>
              <h3 class="text-xl font-bold mt-1">Penguji Eksternal UKK TKJ</h3>
              <p class="text-slate-500 font-medium mb-2"><a href="https://diskominfo.baubaukota.go.id/" target="_blank" class="hover:text-indigo-600 transition-colors">Diskominfo Kota Baubau</a> & <a href="/tulisan/ukk-smkn4-baubau-diskominfo/" class="hover:text-indigo-600 transition-colors">SMKN 4 Baubau</a></p>
              <p class="text-slate-600 text-sm leading-relaxed">Mewakili instansi pemerintah untuk menguji kompetensi keahlian siswa Teknik Komputer dan Jaringan (MikroTik, Network Security, Bandwidth Management).</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">2017 - Present</span>
              <h3 class="text-xl font-bold mt-1">Founder & Lead Instructor</h3>
              <p class="text-slate-500 font-medium mb-2"><a href="https://pondokinformatika.id" target="_blank" class="hover:text-indigo-600 transition-colors">Yayasan Pondok Informatika</a></p>
              <p class="text-slate-600 text-sm leading-relaxed">Holding a position as the leader and mentor. Acting as the primary instructor for IT and Web Development training, issuing official certificates of competency.</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Jan - July 2021</span>
              <h3 class="text-xl font-bold mt-1">Back End Developer</h3>
              <p class="text-slate-500 font-medium mb-2">PT. Jagona Era Teknologi</p>
              <p class="text-slate-600 text-sm leading-relaxed">Building a Web Administrator using Codeigniter, creating REST APIs.</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">2013 - 2014</span>
              <h3 class="text-xl font-bold mt-1">Web Developer</h3>
              <p class="text-slate-500 font-medium mb-2">CV. VISUALDATA</p>
              <p class="text-slate-600 text-sm leading-relaxed">Designing an Online Shop using OpenCart CMS and Customization using PHP.</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">2011 - 2012</span>
              <h3 class="text-xl font-bold mt-1">IT Staff & Database</h3>
              <p class="text-slate-500 font-medium mb-2">STIBA MAKASSAR</p>
              <p class="text-slate-600 text-sm leading-relaxed">Managing Student Database and Registration Administration, Designing Desktop App-based Academic Management System, Graphic Design, & IT Support.</p>
            </div>
          </div>
        </div>

        <!-- Education Column -->
        <div>
          <div class="mb-12">
            <h2 class="text-3xl font-bold mb-2">Education</h2>
            <div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
          </div>

          <div class="space-y-8">
            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-indigo-600 uppercase tracking-wider">Ongoing</span>
              <h3 class="text-xl font-bold mt-1">Master of Information Technology (S2)</h3>
              <p class="text-slate-500 font-medium mb-2">International Open University (IOU)</p>
              <p class="text-slate-600 text-sm leading-relaxed">Advanced studies in IT with a focus on modern software architecture and systems.</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">2006 - 2011</span>
              <h3 class="text-xl font-bold mt-1">Teknik Informatika (S1)</h3>
              <p class="text-slate-500 font-medium mb-2">Universitas Dipa Makassar</p>
              <p class="text-slate-600 text-sm leading-relaxed">Bachelor's degree in Computer Science.</p>
            </div>

            <div class="relative pl-8 border-l-2 border-slate-100">
              <div class="absolute -left-[9px] top-0 w-4 h-4 bg-indigo-600 rounded-full border-4 border-white"></div>
              <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">2017 - 2020</span>
              <h3 class="text-xl font-bold mt-1">Back End Developer</h3>
              <p class="text-slate-500 font-medium mb-2">Pondok Informatika</p>
              <p class="text-slate-600 text-sm leading-relaxed">Intensive specialized training in server-side development and database management.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

		<!-- Portfolio Section -->
		<section id="portfolio" class="mb-20">
			<div class="mb-12">
				<h2 class="text-3xl font-bold mb-2">Featured Portfolio</h2>
				<div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
			</div>
			
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{projects.slice(0, 6).map((project) => (
					<div class="project-card group bg-white border border-slate-100 rounded-2xl overflow-hidden hover:shadow-xl transition-all flex flex-col h-full" data-langs={JSON.stringify(project.available_langs)}>
						<img src={(project.image && project.image.startsWith('http')) ? project.image : '/' + (project.image || 'img/screenshots/default.png')} alt={project.title} class="w-full h-48 object-cover group-hover:scale-105 transition-all duration-500" />
						<div class="p-6 flex flex-col flex-grow">
							<h3 class="text-xl font-bold mb-2 project-title" data-id={project.title} data-en={project.title_en}>{project.title}</h3>
							<p class="text-slate-600 text-sm mb-4 line-clamp-2 project-desc" data-id={project.description} data-en={project.description_en}>{project.description}</p>
							<div class="flex justify-between items-center mt-auto pt-4 border-t border-slate-50">
								<span class="text-xs font-bold text-slate-400 uppercase tracking-wider">{project.category}</span>
								<a href={project.url} target="_blank" class="text-indigo-600 font-bold text-sm">Visit Site →</a>
							</div>
						</div>
					</div>
				))}
			</div>
      
      <div class="mt-12 text-center">
        <a href="/portofolio/" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:gap-4 transition-all">
          Lihat Semua Portofolio <span class="text-xl">→</span>
        </a>
      </div>
		</section>

		<!-- Writings Section -->
		<section id="writing" class="mb-20">
			<div class="mb-12">
				<h2 class="text-3xl font-bold mb-2">Recent Writings</h2>
				<div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
			</div>

			<div class="grid md:grid-cols-2 gap-8" id="writingGrid">
				{writings.slice(0, 4).map((writing) => (
					<a href={`/tulisan/${writing.slug}/`} class="writing-card flex gap-6 p-6 bg-slate-50 rounded-2xl hover:bg-white border border-transparent hover:border-slate-100 transition-all group" data-langs={JSON.stringify(writing.available_langs)}>
						<img src={(writing.image && writing.image.startsWith('http')) ? writing.image : '/' + (writing.image || 'img/screenshots/default.png')} alt={writing.title} class="w-24 h-24 object-cover rounded-xl shadow-sm group-hover:scale-105 transition-all" />
						<div class="flex-1">
							<span class="text-xs font-bold text-indigo-600 uppercase mb-2 block">{writing.category}</span>
							<h3 class="text-xl font-bold mb-3 group-hover:text-indigo-600 transition-colors writing-title" data-id={writing.title} data-en={writing.title_en}>{writing.title}</h3>
							<p class="text-slate-500 text-sm mb-4 line-clamp-2 writing-desc" data-id={writing.description} data-en={writing.description_en}>{writing.description}</p>
							<div class="flex items-center gap-2 text-slate-400 text-xs">
								<span>{writing.date}</span>
							</div>
						</div>
					</a>
				))}
			</div>

      <div class="mt-12 text-center">
        <a href="/tulisan/" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:gap-4 transition-all">
          Lihat Semua Tulisan <span class="text-xl">→</span>
        </a>
      </div>
		</section>
	</main>

	<footer class="border-t border-slate-100 py-12 mt-20">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="logo font-black text-xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
          MUHDAN FYAN
        </div>
        <div class="flex gap-8">
          <a href="https://www.linkedin.com/in/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">LinkedIn</span>
          </a>
          <a href="https://www.facebook.com/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">Facebook</span>
          </a>
          <a href="https://www.instagram.com/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">Instagram</span>
          </a>
        </div>
        <p class="text-slate-400 text-sm font-medium">
          &copy; 2026 Muhdan Fyan Syah Sofian.
        </p>
      </div>
    </div>
	</footer>

  <script is:inline>
    let currentLang = localStorage.getItem('lang') || 'id';

    function updateLanguageUI() {
      document.getElementById('langLabel').innerText = currentLang.toUpperCase();
      
      // Update Projects
      document.querySelectorAll('.project-card').forEach(card => {
        const langs = JSON.parse(card.dataset.langs || '["id"]');
        card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
        
        const titleEl = card.querySelector('.project-title');
        const descEl = card.querySelector('.project-desc');
        if (titleEl) titleEl.innerText = currentLang === 'en' ? titleEl.dataset.en : titleEl.dataset.id;
        if (descEl) descEl.innerText = currentLang === 'en' ? descEl.dataset.en : descEl.dataset.id;
      });

      // Update Writings
      document.querySelectorAll('.writing-card').forEach(card => {
        const langs = JSON.parse(card.dataset.langs || '["id"]');
        card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
        
        const titleEl = card.querySelector('.writing-title');
        const descEl = card.querySelector('.writing-desc');
        if (titleEl) titleEl.innerText = currentLang === 'en' ? titleEl.dataset.en : titleEl.dataset.id;
        if (descEl) descEl.innerText = currentLang === 'en' ? descEl.dataset.en : descEl.dataset.id;
      });
    }

    document.getElementById('langToggle').addEventListener('click', () => {
      currentLang = currentLang === 'id' ? 'en' : 'id';
      localStorage.setItem('lang', currentLang);
      updateLanguageUI();
    });

    // Initial run
    updateLanguageUI();
  </script>
</Layout>
