					<a href="https://github.com/muhdanfyan" target="_blank" class="border border-slate-200 px-8 py-3 rounded-xl font-bold hover:bg-slate-50 transition-all">
						GitHub
					</a>
				</div>
			</div>
		</section>

    <!-- Experience & Education Section -->
    <section id="resume" class="mb-20">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Experience Column -->
        <div>
          <div class="mb-12">
            <h2 class="text-3xl font-bold mb-2 lang-text" data-id="Pengalaman Profesional" data-en="Professional Experience">Pengalaman Profesional</h2>
            <div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
          </div>
          
          <div class="space-y-8">
            {experience.map((exp) => (
              <div class="relative pl-8 border-l-2 border-slate-100">
