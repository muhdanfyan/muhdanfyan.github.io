---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';
const projectsDir = path.join(process.cwd(), 'content/portfolio');
const projectFolders = fs.existsSync(projectsDir) ? fs.readdirSync(projectsDir) : [];
const projects = projectFolders.map(slug => {
  const filePath = path.join(projectsDir, slug, 'index.mdoc');
  if (!fs.existsSync(filePath)) return null;
  const { data } = matter(fs.readFileSync(filePath, 'utf-8'));
  return { ...data, slug };
}).filter(Boolean).sort((a, b) => (b.is_featured ? 1 : 0) - (a.is_featured ? 1 : 0));

const stripMarkdown = (text) => {
  if (!text) return '';
  return text
    .replace(/!\[.*?\]\(.*?\)/g, '') // remove images
    .replace(/\[(.*?)\]\(.*?\)/g, '$1') // keep link text only
    .replace(/[*_~`]/g, '') // remove formatting
    .replace(/#+\s/g, '') // remove headings
    .replace(/>\s/g, '') // remove blockquotes
    .replace(/\n+/g, ' ') // replace newlines with space
    .trim();
};

const experienceDir = path.join(process.cwd(), 'content/experience');
const experience = (fs.existsSync(experienceDir) ? fs.readdirSync(experienceDir) : [])
  .map(slug => {
    const filePath = path.join(experienceDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    const { data, content } = matter(fs.readFileSync(filePath, 'utf-8'));
    return { ...data, content: stripMarkdown(content), slug };
  })
  .filter(Boolean)
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const educationDir = path.join(process.cwd(), 'content/education');
const education = (fs.existsSync(educationDir) ? fs.readdirSync(educationDir) : [])
  .map(slug => {
    const filePath = path.join(educationDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    const { data, content } = matter(fs.readFileSync(filePath, 'utf-8'));
    return { ...data, content: stripMarkdown(content), slug };
  })
  .filter(Boolean)
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const teachingDir = path.join(process.cwd(), 'content/teaching');
const teaching = (fs.existsSync(teachingDir) ? fs.readdirSync(teachingDir) : [])
  .map(slug => {
    const filePath = path.join(teachingDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    const { data, content } = matter(fs.readFileSync(filePath, 'utf-8'));
    return { ...data, content: stripMarkdown(content), slug };
  })
  .filter(Boolean)
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const tulisanDir = path.join(process.cwd(), 'tulisan');
const folders = fs.existsSync(tulisanDir) ? fs.readdirSync(tulisanDir) : [];
const writings = folders
  .map((slug) => {
    const filePath = path.join(tulisanDir, slug, 'index.mdoc');
    if (!fs.existsSync(filePath)) return null;
    const fileContent = fs.readFileSync(filePath, 'utf-8');
    const { data } = matter(fileContent);
    const hasEnFile = fs.existsSync(path.join(tulisanDir, slug, 'index.en.mdoc')) || 
                      fs.existsSync(path.join(tulisanDir, slug, 'tulisan.en.mdoc')) ||
                      fs.existsSync(path.join(tulisanDir, slug, 'tulisan.en.md'));
    
    return {
      slug,
      title: data.title_id || slug,
      title_en: data.title_en || slug,
      date: data.date || '',
      category: data.category || 'General',
      description: data.description_id || '',
      description_en: data.description_en || '',
      image: data.image || '',
      available_langs: (data.content_en_markdown || hasEnFile) ? ['id', 'en'] : ['id']
    };
  })
  .filter(Boolean)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
