      <div class="mt-12 text-center">
        <a href="/portofolio/" class="inline-flex items-center gap-2 text-indigo-600 font-bold hover:gap-4 transition-all lang-text"
           data-id="Lihat Semua Portofolio" data-en="View All Portfolio">
          Lihat Semua Portofolio <span class="text-xl">→</span>
        </a>
      </div>
		</section>

		<!-- Writings Section -->
		<section id="writing" class="mb-20">
			<div class="mb-12">
				<h2 class="text-3xl font-bold mb-2 lang-text" data-id="Tulisan Terbaru" data-en="Recent Writings">Tulisan Terbaru</h2>
				<div class="w-12 h-1 bg-indigo-600 rounded-full"></div>
			</div>

			<div class="grid md:grid-cols-2 gap-8" id="writingGrid">
				{writings.slice(0, 4).map((w) => (
					<a href={`/writing/${w.slug}/`} class="writing-card flex gap-6 p-6 bg-slate-50 rounded-2xl hover:bg-white border border-transparent hover:border-slate-100 transition-all group" data-langs={JSON.stringify(w.available_langs)}>
						<img src={(w.image && w.image.startsWith('http')) ? w.image : (w.image?.startsWith('/') ? w.image : (w.image?.startsWith('img/') ? '/' + w.image : `/img/writing/${w.image || 'default.png'}`))} alt={w.title} class="w-24 h-24 object-cover rounded-xl shadow-sm group-hover:scale-105 transition-all" />
