                <h3 class="text-xl font-bold mt-1 lang-text" data-id={exp.position} data-en={exp.position_en}>{exp.position}</h3>
                <p class="text-slate-500 font-medium mb-2">{exp.link ? <a href={exp.link} target="_blank" class="hover:text-indigo-600 transition-colors">{exp.company}</a> : exp.company}</p>
