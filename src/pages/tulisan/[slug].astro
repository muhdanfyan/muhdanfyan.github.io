  <script is:inline define:vars={{ slug }}>
    const synth = window.speechSynthesis;
    let voices = [];
    let audioCtx = null;
    let oscillator = null;
    let gainNode = null;
    let resumeTimer = null;

    function loadVoices() { voices = synth.getVoices(); }
    if (synth.onvoiceschanged !== undefined) { synth.onvoiceschanged = loadVoices; }
    loadVoices();

    function startKeepAlive() {
      if (audioCtx) return;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      oscillator = audioCtx.createOscillator();
      gainNode = audioCtx.createGain();
      gainNode.gain.value = 0.001;
      oscillator.frequency.value = 1;
      oscillator.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      oscillator.start();
    }

    function stopKeepAlive() {
      if (oscillator) { try { oscillator.stop(); } catch(e){} oscillator = null; }
      if (audioCtx) { audioCtx.close(); audioCtx = null; }
      gainNode = null;
    }

    function startResumeHack() {
      clearInterval(resumeTimer);
      resumeTimer = setInterval(() => {
        if (synth.speaking && !synth.paused) {
          synth.pause();
          synth.resume();
        }
      }, 10000);
    }
    function stopResumeHack() { clearInterval(resumeTimer); }

    function updateMediaSession() {
      if (!('mediaSession' in navigator)) return;
      const title = document.querySelector('h1')?.innerText || 'Tulisan';
      const image = document.querySelector('header img')?.src || '';
      navigator.mediaSession.metadata = new MediaMetadata({
        title: title, artist: 'Muhdan Fyan', album: 'AI Voice Reader',
        artwork: [{ src: image, sizes: '512x512', type: 'image/jpeg' }]
      });
      navigator.mediaSession.setActionHandler('play', () => { if (window.toggleAudio) window.toggleAudio(); });
      navigator.mediaSession.setActionHandler('pause', () => { if (window.toggleAudio) window.toggleAudio(); });
    }

    function initLanguage() {
      let currentLang = localStorage.getItem('lang') || 'id';
      function updateLanguageUI() {
        const label = document.getElementById('langLabel');
        if (label) label.innerText = currentLang.toUpperCase();
        document.querySelectorAll('.lang-text').forEach(el => {
          el.innerText = currentLang === 'en' ? el.dataset.en : el.dataset.id;
        });
        const idC = document.getElementById('contentId'), enC = document.getElementById('contentEn');
        if (idC && enC) { idC.classList.toggle('hidden', currentLang === 'en'); enC.classList.toggle('hidden', currentLang !== 'en'); }
      }
      const langToggle = document.getElementById('langToggle');
      if (langToggle) {
        const n = langToggle.cloneNode(true); langToggle.parentNode.replaceChild(n, langToggle);
        n.addEventListener('click', () => { 
          // If English version exists, redirect to /en/ route
          const hasEn = document.getElementById('contentEn') && !document.getElementById('contentEn').innerHTML.includes('marked('); // Simple check if content exists
          if (hasEn) {
            localStorage.setItem('lang', 'en');
            window.location.href = `/en/tulisan/${slug}`;
          } else {
            currentLang = currentLang === 'id' ? 'en' : 'id'; 
            localStorage.setItem('lang', currentLang); 
            updateLanguageUI(); 
          }
          if (window.stopAudio) window.stopAudio(); 
        });
      }
      const copyBtn = document.getElementById('copyText');
      if (copyBtn) {
        const n = copyBtn.cloneNode(true); copyBtn.parentNode.replaceChild(n, copyBtn);
        n.addEventListener('click', async () => {
          const c = currentLang === 'en' ? document.getElementById('contentEn') : document.getElementById('contentId');
          try { await navigator.clipboard.writeText(c.innerText); const l = n.querySelector('#copyLabel'); const o = l.innerText; l.innerText = currentLang === 'en' ? 'Copied!' : 'Tersalin!'; setTimeout(() => { l.innerText = o; }, 2000); } catch(e) {}
        });
      }
      const shareIG = document.getElementById('shareIG');
      if (shareIG) {
        const n = shareIG.cloneNode(true); shareIG.parentNode.replaceChild(n, shareIG);
        n.addEventListener('click', () => { if (navigator.share) { navigator.share({ title: document.querySelector('h1').innerText, url: window.location.href }); } else { navigator.clipboard.writeText(window.location.href); alert('Link copied!'); } });
      }
      updateLanguageUI();
    }

    function formatTime(seconds) {
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    }

    function initAudioPlayer() {
      let utterance = null, isPlaying = false, currentText = '', lastCharIndex = 0, charOffset = 0, progressInterval = null;
      let totalSeconds = 0;
      const playBtn = document.getElementById('playAudio');
      if (!playBtn) return;
      const playIcon = document.getElementById('playIcon'), pauseIcon = document.getElementById('pauseIcon');
      const progressBar = document.getElementById('progressBar'), audioProgressText = document.getElementById('audioProgress');
      const silentAudio = document.getElementById('silentAudio');
      const getStorageKey = () => `audio_progress_${window.location.pathname}_${localStorage.getItem('lang') || 'id'}`;

      function estimateTotalTime(text) {
        // Average speaking rate: ~15 characters per second
        return Math.ceil(text.length / 15);
      }

      function updateProgress(ci) {
        const abs = ci + charOffset; lastCharIndex = abs;
        const p = Math.min((abs / (currentText.length || 1)) * 100, 100);
        progressBar.style.width = `${p}%`;
        
        // Countdown timer
        const remainingChars = currentText.length - abs;
        const remainingSeconds = Math.max(0, Math.ceil(remainingChars / 15));
        audioProgressText.innerText = formatTime(remainingSeconds);
        
        localStorage.setItem(getStorageKey(), abs);
      }

      function startProgressTimer() {
        clearInterval(progressInterval);
        progressInterval = setInterval(() => { if (synth.speaking && !synth.paused) { lastCharIndex += 1; updateProgress(lastCharIndex - charOffset); } }, 150);
      }

      function setUI(playing) {
        isPlaying = playing;
        playIcon.classList.toggle('hidden', playing); pauseIcon.classList.toggle('hidden', !playing);
        if ('mediaSession' in navigator) navigator.mediaSession.playbackState = playing ? 'playing' : 'paused';
      }

      window.stopAudio = () => {
        synth.cancel(); silentAudio.pause(); stopKeepAlive(); stopResumeHack();
        clearInterval(progressInterval); setUI(false);
        if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'none';
      };

      function startSpeaking() {
        synth.cancel();
        const lang = localStorage.getItem('lang') || 'id';
        const c = lang === 'en' ? document.getElementById('contentEn') : document.getElementById('contentId');
        currentText = c.innerText.trim(); if (!currentText) return;
        
        totalSeconds = estimateTotalTime(currentText);
        
        const saved = parseInt(localStorage.getItem(getStorageKey())) || 0;
        charOffset = saved >= currentText.length ? 0 : saved; lastCharIndex = charOffset;
        utterance = new SpeechSynthesisUtterance(currentText.substring(charOffset));
        utterance.lang = lang === 'id' ? 'id-ID' : 'en-US'; utterance.rate = 0.95;
        const preferred = ['Damayanti', 'Ardi', 'Indah', 'Natural', 'Enhanced', 'Premium'];
        // Try to find a native-sounding Indonesian voice
        let bv = voices.find(v => (v.lang.includes('id') || v.lang.includes('ID')) && !v.name.includes('Google') && preferred.some(k => v.name.includes(k)));
        if (!bv) bv = voices.find(v => (v.lang.includes('id') || v.lang.includes('ID')) && !v.name.includes('Google'));
        if (bv) utterance.voice = bv;
        // If no high-quality voice found, we don't set utterance.voice to let browser use device default
        utterance.onstart = () => { startProgressTimer(); startResumeHack(); };
        utterance.onboundary = (e) => updateProgress(e.charIndex);
        utterance.onend = () => { window.stopAudio(); progressBar.style.width = '0%'; audioProgressText.innerText = '00:00'; localStorage.removeItem(getStorageKey()); };
        utterance.onerror = window.stopAudio;
        updateMediaSession();
        startKeepAlive();
        silentAudio.play().catch(()=>{});
        synth.speak(utterance);
      }

      window.toggleAudio = () => {
        if (isPlaying) {
          synth.pause(); silentAudio.pause(); stopResumeHack(); clearInterval(progressInterval); setUI(false);
        } else {
          if (synth.paused && utterance) { synth.resume(); silentAudio.play().catch(()=>{}); startProgressTimer(); startResumeHack(); }
          else { startSpeaking(); }
          setUI(true);
        }
      };

      const np = playBtn.cloneNode(true); playBtn.parentNode.replaceChild(np, playBtn);
      np.addEventListener('click', window.toggleAudio);
      const pc = document.getElementById('progressContainer');
      if (pc) { pc.addEventListener('click', (e) => { if (!currentText) return; const r = e.currentTarget.getBoundingClientRect(); localStorage.setItem(getStorageKey(), Math.floor(((e.clientX - r.left) / r.width) * currentText.length)); startSpeaking(); setUI(true); }); }
      
      // Initialize with estimated time if not playing
      const lang = localStorage.getItem('lang') || 'id';
      const c = lang === 'en' ? document.getElementById('contentEn') : document.getElementById('contentId');
      if (c) {
        const text = c.innerText.trim();
        const saved = parseInt(localStorage.getItem(getStorageKey())) || 0;
        const remainingChars = text.length - (saved >= text.length ? 0 : saved);
        audioProgressText.innerText = formatTime(Math.max(0, Math.ceil(remainingChars / 15)));
        const p = Math.min(((saved >= text.length ? 0 : saved) / (text.length || 1)) * 100, 100);
        progressBar.style.width = `${p}%`;
      }
    }

    function initCodeBoxes() {
      document.querySelectorAll('.prose pre').forEach(pre => {
        if (pre.parentElement.classList.contains('code-box-wrapper')) return;

        // Wrap pre in a container
        const wrapper = document.createElement('div');
        wrapper.className = 'code-box-wrapper group';
        
        const code = pre.querySelector('code');
        const lang = Array.from(code.classList).find(c => c.startsWith('language-'))?.replace('language-', '') || 'code';
        
        // Header with language and copy button
        const header = document.createElement('div');
        header.className = 'code-box-header';
        header.innerHTML = `
          <span class="code-lang">${lang.toUpperCase()}</span>
          <button class="copy-code-btn" title="Copy Code">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            <span class="copy-label">Copy</span>
          </button>
        `;

        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(header);
        wrapper.appendChild(pre);

        const copyBtn = header.querySelector('.copy-code-btn');
        const copyLabel = header.querySelector('.copy-label');

        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code.innerText);
            copyLabel.innerText = 'Copied!';
            copyBtn.classList.add('copied');
            setTimeout(() => {
              copyLabel.innerText = 'Copy';
              copyBtn.classList.remove('copied');
            }, 2000);
          } catch (err) {}
        });
      });
    }

    document.addEventListener('astro:page-load', () => { 
      initLanguage(); 
      initAudioPlayer(); 
      initCodeBoxes();
    });
    initLanguage(); initAudioPlayer(); initCodeBoxes();
  </script>
</Layout>

