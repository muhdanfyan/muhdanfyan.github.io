---
import Layout from '../../layouts/Layout.astro';
import manifest from '../../../data/manifest.json';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  return manifest.writing.map((w) => ({
    params: { slug: w.slug },
  }));
}

const { slug } = Astro.params;
const writing = manifest.writing.find((item) => item.slug === slug);

if (!writing) {
  return Astro.redirect('/404');
}

// Read markdown files
const contentDir = path.join(process.cwd(), 'tulisan', slug);
const idPath = path.join(contentDir, 'tulisan.md');
const enPath = path.join(contentDir, 'tulisan.en.md');

let htmlId = '';
let htmlEn = '';

if (fs.existsSync(idPath)) {
  const content = fs.readFileSync(idPath, 'utf-8');
  htmlId = marked(content);
}

if (fs.existsSync(enPath)) {
  const content = fs.readFileSync(enPath, 'utf-8');
  htmlEn = marked(content);
} else {
  htmlEn = htmlId; // Fallback
}
---

<Layout 
  title={`${writing.title} | Muhdan Fyan`}
  description={writing.description}
  image={writing.image.startsWith('http') ? writing.image : `https://muhdanfyan.github.io/${writing.image}`}
>
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="logo font-black text-2xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
        MUHDAN FYAN
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="text-sm font-bold text-slate-600 hover:text-indigo-600 lang-text" data-id="Beranda" data-en="Home">Beranda</a>
        <button id="langToggle" class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-sm font-bold hover:bg-indigo-600 hover:text-white transition-all">
          <span id="langLabel">ID</span>
        </button>
      </div>
    </div>
  </nav>

  <article class="container mx-auto px-6 pt-32 pb-20 max-w-4xl">
    <header class="mb-12">
      <div class="flex items-center gap-4 text-slate-400 text-sm font-bold uppercase tracking-wider mb-4">
        <span>{writing.category}</span>
        <span>•</span>
        <span>{writing.date}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-8 leading-tight lang-text"
          data-id={writing.title} data-en={writing.title_en}>
        {writing.title}
      </h1>
      <img src={writing.image.startsWith('http') ? writing.image : `/${writing.image}`} alt={writing.title} class="w-full h-[400px] object-cover rounded-3xl shadow-2xl mb-12" />
    </header>

    <div class="prose prose-indigo prose-lg max-w-none">
      <div id="contentId" class="lang-content" set:html={htmlId}></div>
      <div id="contentEn" class="lang-content hidden" set:html={htmlEn}></div>
    </div>
  </article>

  <footer class="border-t border-slate-100 py-12 mt-20">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="logo font-black text-xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
          MUHDAN FYAN
        </div>
        <div class="flex gap-8">
          <a href="https://www.linkedin.com/in/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">LinkedIn</span>
          </a>
          <a href="https://www.facebook.com/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">Facebook</span>
          </a>
          <a href="https://www.instagram.com/muhdanfyan" class="group flex items-center gap-2 text-slate-400 hover:text-indigo-600 transition-all" target="_blank">
            <span class="text-lg">Instagram</span>
          </a>
        </div>
        <p class="text-slate-400 text-sm font-medium">
          &copy; 2026 Muhdan Fyan Syah Sofian.
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    let currentLang = localStorage.getItem('lang') || 'id';

    function updateLanguageUI() {
      document.getElementById('langLabel').innerText = currentLang.toUpperCase();
      
      // Update General Text
      document.querySelectorAll('.lang-text').forEach(el => {
        el.innerText = currentLang === 'en' ? el.dataset.en : el.dataset.id;
      });

      // Update Article Content
      const idContent = document.getElementById('contentId');
      const enContent = document.getElementById('contentEn');
      
      if (currentLang === 'en') {
        idContent.classList.add('hidden');
        enContent.classList.remove('hidden');
      } else {
        idContent.classList.remove('hidden');
        enContent.classList.add('hidden');
      }
    }

    document.getElementById('langToggle').addEventListener('click', () => {
      currentLang = currentLang === 'id' ? 'en' : 'id';
      localStorage.setItem('lang', currentLang);
      updateLanguageUI();
    });

    updateLanguageUI();
  </script>
</Layout>

<style is:global>
  .lang-content.hidden {
    display: none;
  }
  /* Basic Prose Styling manually since we don't have typography plugin yet */
  .prose h1, .prose h2, .prose h3 { color: #0f172a; margin-top: 2rem; margin-bottom: 1rem; font-family: 'Outfit', sans-serif; }
  .prose p { margin-bottom: 1.5rem; color: #334155; line-height: 1.8; }
  .prose ul { list-style: disc; margin-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose blockquote { border-left: 4px solid #6366f1; padding-left: 1.5rem; font-style: italic; color: #475569; margin: 2rem 0; }
  
  .dropcap::first-letter {
    float: left;
    font-size: 4.5rem;
    line-height: 1;
    font-weight: 800;
    margin-right: 0.75rem;
    color: #6366f1;
    font-family: 'Outfit', sans-serif;
  }

  .highlight {
    background: linear-gradient(120deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%);
    background-repeat: no-repeat;
    background-size: 100% 0.4em;
    background-position: 0 88%;
    font-weight: 600;
    color: #4338ca;
    padding: 0 0.2rem;
    font-family: 'JetBrains Mono', monospace;
  }
</style>
