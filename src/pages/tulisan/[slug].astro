          </a>
          <a href="https://wa.me/6285796792110" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="WhatsApp">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.98zm11.387-5.464c-.301-.15-1.779-.877-2.053-.976-.275-.1-.475-.15-.675.15-.199.301-.775.976-.951 1.176-.175.199-.35.225-.651.075-.301-.15-1.267-.467-2.414-1.49-.893-.797-1.495-1.782-1.671-2.081-.175-.301-.019-.463.131-.612.135-.133.301-.351.452-.526.149-.175.199-.301.299-.501.101-.199.051-.376-.025-.526-.075-.15-.675-1.628-.925-2.229-.244-.588-.491-.508-.675-.508-.174-.001-.374-.001-.574-.001-.2 0-.526.075-.802.376-.275.301-1.051 1.026-1.051 2.504 0 1.477 1.076 2.904 1.226 3.104.15.199 2.118 3.235 5.13 4.537.716.31 1.275.496 1.71.636.72.228 1.375.196 1.892.119.577-.085 1.779-.726 2.028-1.427.25-.701.25-1.302.175-1.427-.075-.125-.275-.199-.575-.35z"/></svg>
          </a>
        </div>
        <p class="text-slate-400 text-sm font-medium">
          &copy; 2026 Muhdan Fyan Syah Sofian.
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    let currentLang = localStorage.getItem('lang') || 'id';

    function updateLanguageUI() {
      document.getElementById('langLabel').innerText = currentLang.toUpperCase();
      
      // Update General Text
      document.querySelectorAll('.lang-text').forEach(el => {
        el.innerText = currentLang === 'en' ? el.dataset.en : el.dataset.id;
      });

      // Update Article Content
      const idContent = document.getElementById('contentId');
      const enContent = document.getElementById('contentEn');
      
      if (currentLang === 'en') {
        idContent.classList.add('hidden');
        enContent.classList.remove('hidden');
      } else {
        idContent.classList.remove('hidden');
        enContent.classList.add('hidden');
      }
    }

    document.getElementById('langToggle').addEventListener('click', () => {
      currentLang = currentLang === 'id' ? 'en' : 'id';
      localStorage.setItem('lang', currentLang);
      updateLanguageUI();
    });

    updateLanguageUI();
  </script>
</Layout>

<style is:global>
  .lang-content.hidden {
    display: none;
  }
  /* Basic Prose Styling manually since we don't have typography plugin yet */
  .prose h1, .prose h2, .prose h3 { color: #0f172a; margin-top: 2rem; margin-bottom: 1rem; font-family: 'Outfit', sans-serif; }
  .prose p { margin-bottom: 1.5rem; color: #334155; line-height: 1.8; }
  .prose ul { list-style: disc; margin-left: 1.5rem; margin-bottom: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose blockquote { border-left: 4px solid #6366f1; padding-left: 1.5rem; font-style: italic; color: #475569; margin: 2rem 0; }
  
  .dropcap::first-letter {
    float: left;
    font-size: 4.5rem;
    line-height: 1;
    font-weight: 800;
    margin-right: 0.75rem;
    color: #6366f1;
    font-family: 'Outfit', sans-serif;
  }

  .highlight {
    background: linear-gradient(120deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%);
    background-repeat: no-repeat;
    background-size: 100% 0.4em;
    background-position: 0 88%;
    font-weight: 600;
    color: #4338ca;
    padding: 0 0.2rem;
    font-family: 'JetBrains Mono', monospace;
  }
</style>
