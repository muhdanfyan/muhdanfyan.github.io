---
import Layout from '../../layouts/Layout.astro';
import manifest from '../../../data/manifest.json';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

import { DocumentRenderer } from '@keystatic/core/renderer';

export async function getStaticPaths() {
  const tulisanDir = path.join(process.cwd(), 'tulisan');
  const folders = fs.readdirSync(tulisanDir);
  
  return folders
    .filter(slug => fs.existsSync(path.join(tulisanDir, slug, 'index.mdoc')))
    .map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
// We no longer need manifest for writing metadata as it's parsed from the file below
const writingManifest = null; 

// Read markdown files
const contentDir = path.join(process.cwd(), 'tulisan', slug);
const idPath = path.join(contentDir, 'index.mdoc');
const enPath = path.join(contentDir, 'tulisan.en.mdoc');

if (!fs.existsSync(idPath)) {
  return Astro.redirect('/404');
}

let htmlId = '';
let contentEnMarkdown = '';
let writingMetadata = { 
  title: '', 
  title_en: '', 
  date: '', 
  category: '', 
  category_en: '', 
  description: '', 
  description_en: '', 
  image: '' 
};

if (fs.existsSync(idPath)) {
  const rawContent = fs.readFileSync(idPath, 'utf-8');
  const { data, content } = matter(rawContent);
  
  if (data.title_id) {
    writingMetadata.title = data.title_id;
    writingMetadata.title_en = data.title_en;
    writingMetadata.date = data.date;
    writingMetadata.category = data.category || '';
    writingMetadata.category_en = data.category_en || data.category || '';
    writingMetadata.description = data.description_id;
    writingMetadata.description_en = data.description_en;
    writingMetadata.image = data.image;
  }

  htmlId = marked(content);

  if (data.content_en_markdown) {
    contentEnMarkdown = data.content_en_markdown;
  }
}

// Fallback to separate English file if Keystatic content_en_markdown is not present
let htmlEnFallback = '';
if (!contentEnMarkdown && fs.existsSync(enPath)) {
  const content = fs.readFileSync(enPath, 'utf-8');
  htmlEnFallback = marked(content);
}

const writing = writingMetadata;
---

<Layout 
  title={`${writing.title} | Muhdan Fyan`}
  description={writing.description}
  image={writing.image.startsWith('http') ? writing.image : `https://muhdanfyan.github.io/img/tulisan/${writing.image}`}
>
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="logo font-black text-2xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
        MUHDAN FYAN
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="text-sm font-bold text-slate-600 hover:text-indigo-600 lang-text" data-id="Beranda" data-en="Home">Beranda</a>
        <button id="langToggle" class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-sm font-bold hover:bg-indigo-600 hover:text-white transition-all">
          <span id="langLabel">ID</span>
        </button>
      </div>
    </div>
  </nav>

  <article class="container mx-auto px-6 pt-32 pb-20 max-w-4xl">
    <header class="mb-12">
      <div class="flex items-center gap-4 text-slate-400 text-sm font-bold uppercase tracking-wider mb-4">
        <span>{writing.category}</span>
        <span>•</span>
        <span>{writing.date}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-8 leading-tight lang-text"
          data-id={writing.title} data-en={writing.title_en}>
        {writing.title}
      </h1>
      <img src={writing.image.startsWith('http') ? writing.image : `/img/tulisan/${writing.image}`} alt={writing.title} class="w-full h-[400px] object-cover rounded-3xl shadow-2xl mb-12" />
    </header>

    <div class="prose prose-indigo prose-lg max-w-none">
      <div id="contentId" class="lang-content" set:html={htmlId}></div>
      <div id="contentEn" class="lang-content hidden">
        {contentEnMarkdown ? <div set:html={marked(contentEnMarkdown)} /> : <div set:html={htmlEnFallback || htmlId} />}
      </div>
    </div>
  </article>

  <footer class="border-t border-slate-100 py-12 mt-20">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="logo font-black text-xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
          MUHDAN FYAN
