          </a>
          <a href="https://www.instagram.com/muhdanfyan" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="Instagram">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-5.838 2.435-5.838 5.838s2.435 5.838 5.838 5.838 5.838-2.435 5.838-5.838-2.435-5.838-5.838-5.838zm0 9.513c-2.03 0-3.675-1.645-3.675-3.675 0-2.03 1.645-3.675 3.675-3.675 2.03 0 3.675 1.645 3.675 3.675 0 2.03-1.645 3.675-3.675 3.675zm5.847-10.846c0 .731-.593 1.323-1.322 1.323-.73 0-1.323-.592-1.323-1.323 0-.73.593-1.322 1.323-1.322.729 0 1.322.592 1.322 1.322z"/></svg>
          </a>
          <a href="https://wa.me/6283134086899" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="WhatsApp">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.98zm11.387-5.464c-.301-.15-1.779-.877-2.053-.976-.275-.1-.475-.15-.675.15-.199.301-.775.976-.951 1.176-.175.199-.35.225-.651.075-.301-.15-1.267-.467-2.414-1.49-.893-.797-1.495-1.782-1.671-2.081-.175-.301-.019-.463.131-.612.135-.133.301-.351.452-.526.149-.175.199-.301.299-.501.101-.199.051-.376-.025-.526-.075-.15-.675-1.628-.925-2.229-.244-.588-.491-.508-.675-.508-.174-.001-.374-.001-.574-.001-.2 0-.526.075-.802.376-.275.301-1.051 1.026-1.051 2.504 0 1.477 1.076 2.904 1.226 3.104.15.199 2.118 3.235 5.13 4.537.716.31 1.275.496 1.71.636.72.228 1.375.196 1.892.119.577-.085 1.779-.726 2.028-1.427.25-.701.25-1.302.175-1.427-.075-.125-.275-.199-.575-.35z"/></svg>
          </a>
        </div>
        <p class="text-slate-400 text-sm font-medium">
          &copy; 2026 Muhdan Fyan Syah Sofian.
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    function updateUI() {
      const currentLang = localStorage.getItem('lang') || 'id';
      const langLabel = document.getElementById('langLabel');
      if (langLabel) langLabel.innerText = currentLang.toUpperCase();
      
      // Update general text
      document.querySelectorAll('.lang-text').forEach(el => {
        if (el instanceof HTMLElement) {
          el.innerText = currentLang === 'en' ? (el.dataset.en || el.innerText) : (el.dataset.id || el.innerText);
        }
      });

      const cards = Array.from(document.querySelectorAll('.writing-card'));
      if (cards.length === 0) return;

      const searchInput = document.getElementById('searchInput');
      const categorySelect = document.getElementById('categorySelect');
      const searchQuery = searchInput ? searchInput.value.toLowerCase() : '';
      const selectedCategory = categorySelect ? categorySelect.value : 'all';
      
      // Filtering
      const filteredCards = cards.filter(card => {
        if (!(card instanceof HTMLElement)) return false;
        const langs = JSON.parse(card.dataset.langs || '["id"]');
        const matchesLang = langs.includes(currentLang);
        const matchesCategory = selectedCategory === 'all' || card.dataset.category === selectedCategory;
        const titleId = (card.dataset.titleId || '').toLowerCase();
        const titleEn = (card.dataset.titleEn || '').toLowerCase();
        const matchesSearch = titleId.includes(searchQuery) || titleEn.includes(searchQuery);
        
        return matchesLang && matchesCategory && matchesSearch;
      });

      // Pagination
      const itemsPerPage = 6;
      const totalPages = Math.ceil(filteredCards.length / itemsPerPage);
      const urlParams = new URLSearchParams(window.location.search);
      let currentPage = parseInt(urlParams.get('page') || '1');
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      cards.forEach(card => { if (card instanceof HTMLElement) card.style.display = 'none'; });
      filteredCards.slice(startIndex, endIndex).forEach(card => {
        if (card instanceof HTMLElement) {
          card.style.display = 'flex';
          const titleEl = card.querySelector('.writing-title');
          const descEl = card.querySelector('.writing-desc');
          if (titleEl instanceof HTMLElement) titleEl.innerText = currentLang === 'en' ? (titleEl.dataset.en || titleEl.innerText) : (titleEl.dataset.id || titleEl.innerText);
          if (descEl instanceof HTMLElement) descEl.innerText = currentLang === 'en' ? (descEl.dataset.en || descEl.innerText) : (descEl.dataset.id || descEl.innerText);
        }
      });

      // Update Pagination Controls
      updatePaginationControls(totalPages, currentPage);
    }

    function updatePaginationControls(totalPages, currentPage) {
      const pageNumbers = document.getElementById('pageNumbers');
      if (!pageNumbers) return;
      pageNumbers.innerHTML = '';
      
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.innerText = i.toString();
        btn.className = `w-10 h-10 rounded-xl font-bold transition-all ${i === currentPage ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-600 hover:bg-slate-100'}`;
        btn.onclick = () => {
          const url = new URL(window.location.href);
          url.searchParams.set('page', i.toString());
          window.history.pushState({}, '', url);
          updateUI();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        pageNumbers.appendChild(btn);
      }

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      if (prevBtn instanceof HTMLButtonElement) prevBtn.disabled = currentPage === 1;
      if (nextBtn instanceof HTMLButtonElement) nextBtn.disabled = currentPage === totalPages || totalPages === 0;
    }

    function init() {
      const langToggle = document.getElementById('langToggle');
      const searchInput = document.getElementById('searchInput');
      const categorySelect = document.getElementById('categorySelect');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');

      if (langToggle) {
        langToggle.addEventListener('click', () => {
          const currentLang = localStorage.getItem('lang') || 'id';
          const newLang = currentLang === 'id' ? 'en' : 'id';
          localStorage.setItem('lang', newLang);
          updateUI();
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          const url = new URL(window.location.href);
          url.searchParams.set('page', '1');
          window.history.pushState({}, '', url);
          updateUI();
        });
      }

      if (categorySelect) {
        categorySelect.addEventListener('change', () => {
          const url = new URL(window.location.href);
          url.searchParams.set('page', '1');
          window.history.pushState({}, '', url);
          updateUI();
        });
      }

      if (prevBtn) {
        prevBtn.onclick = () => {
          const urlParams = new URLSearchParams(window.location.search);
          const currentPage = parseInt(urlParams.get('page') || '1');
          if (currentPage > 1) {
            const url = new URL(window.location.href);
            url.searchParams.set('page', (currentPage - 1).toString());
            window.history.pushState({}, '', url);
            updateUI();
          }
        };
      }

      if (nextBtn) {
        nextBtn.onclick = () => {
          const urlParams = new URLSearchParams(window.location.search);
          const currentPage = parseInt(urlParams.get('page') || '1');
          const url = new URL(window.location.href);
          url.searchParams.set('page', (currentPage + 1).toString());
          window.history.pushState({}, '', url);
          updateUI();
        };
      }

      updateUI();
    }

    // Run on initial load and after each navigation
    init();
    document.addEventListener('astro:page-load', init);
  </script>

  <style>
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
</Layout>
