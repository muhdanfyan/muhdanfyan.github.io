---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
  description?: string;
  image?: string;
  isHome?: boolean;
}

const { title, description = "Muhdan Fyan | Full Stack Developer & Dakwah IT Specialist", image = "/img/screenshots/default.png", isHome = false } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
    <ClientRouter />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="canonical" href={`https://muhdanfyan.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Muhdan Fyan Portfolio" />
    <meta property="og:url" content={`https://muhdanfyan.github.io${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content={Astro.url.pathname.startsWith('/writing/') ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:secure_url" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={image.toLowerCase().endsWith('.png') ? 'image/png' : 'image/jpeg'} />
    <meta property="og:image:alt" content={title} />
    <meta itemprop="image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@muhdanfyan" />
    <meta name="twitter:creator" content="@muhdanfyan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Muhdan Fyan Syah Sofian" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Muhdan Fyan Syah Sofian",
      "url": "https://muhdanfyan.github.io",
      "jobTitle": "Full Stack Developer",
      "knowsAbout": ["Web Development", "PHP", "Laravel", "React", "TypeScript", "AI", "Mobile Development"],
      "sameAs": [
        "https://linkedin.com/in/muhdanfyan",
        "https://github.com/muhdanfyan",
        "https://instagram.com/muhdanfyan"
      ]
    }
    </script>
	</head>
	<body class="bg-white text-slate-900 font-sans min-h-screen flex flex-col">
    <!-- Global Navigation -->
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
      <div class="container mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="logo font-black text-2xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
          MUHDAN FYAN
        </a>
        <div class="flex items-center gap-6">
          {isHome ? (
            <>
              <a href="#portfolio" class="text-sm font-bold text-slate-600 hover:text-indigo-600 hidden md:block">Portfolio</a>
              <a href="#writing" class="text-sm font-bold text-slate-600 hover:text-indigo-600 hidden md:block">Writing</a>
            </>
          ) : (
            <a href="/" class="text-sm font-bold text-slate-600 hover:text-indigo-600 lang-text" data-id="Beranda" data-en="Home">Beranda</a>
          )}
          <button id="langToggle" class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-sm font-bold hover:bg-indigo-600 hover:text-white transition-all">
            <span id="langLabel">ID</span>
          </button>
        </div>
      </div>
    </nav>

    <div class="flex-grow">
		  <slot />
    </div>

    <!-- Global Footer -->
    <footer class="border-t border-slate-100 py-12 mt-20">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <div class="logo font-black text-xl bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
            MUHDAN FYAN
          </div>
          <div class="flex gap-6">
            <a href="https://www.linkedin.com/in/muhdanfyan" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="LinkedIn">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="https://www.facebook.com/muhdanfyan" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="Facebook">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 3.656 10.99 8.812 12.003v-8.49h-3.087v-3.513h3.087v-2.677c0-3.047 1.803-4.733 4.693-4.733 1.384 0 2.831.247 2.831.247v3.113h-1.595c-1.507 0-1.977.935-1.977 1.892v2.258h3.509l-.56 3.513h-2.949v8.49c5.156-1.013 8.812-6.013 8.812-12.003z"/></svg>
            </a>
            <a href="https://www.instagram.com/muhdanfyan" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="Instagram">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204 0.013-3.583 0.07-4.849 0.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0 3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-5.838 2.435-5.838 5.838s2.435 5.838 5.838 5.838 5.838-2.435-5.838-5.838-2.435-5.838-5.838-5.838zm0 9.513c-2.03 0-3.675-1.645-3.675-3.675 0-2.03 1.645-3.675 3.675-3.675 2.03 0 3.675 1.645 3.675 3.675 0 2.03-1.645 3.675-3.675 3.675zm5.847-10.846c0 .731-.593 1.323-1.322 1.323-.73 0-1.323-.592-1.323-1.323 0-.73.593-1.322 1.323-1.322.729 0 1.322.592 1.322 1.322z"/></svg>
            </a>
            <a href="https://wa.me/6283134086899" class="group text-slate-400 hover:text-indigo-600 transition-all" target="_blank" aria-label="WhatsApp">
              <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.98zm11.387-5.464c-.301-.15-1.779-.877-2.053-.976-.275-.1-.475-.15-.675.15-.199.301-.775.976-.951 1.176-.175.199-.35.225-.651.075-.301-.15-1.267-.467-2.414-1.49-.893-.797-1.495-1.782-1.671-2.081-.175-.301-.019-.463.131-.612.135-.133.301-.351.452-.526.149-.175.199-.301.299-.501.101-.199.051-.376-.025-.526-.075-.15-.675-1.628-.925-2.229-.244-.588-.491-.508-.675-.508-.174-.001-.374-.001-.574-.001-.2 0-.526.075-.802.376-.275.301-1.051 1.026-1.051 2.504 0 1.477 1.076 2.904 1.226 3.104.15.199 2.118 3.235 5.13 4.537.716.31 1.275.496 1.71.636.72.228 1.375.196 1.892.119.577-.085 1.779-.726 2.028-1.427.25-.701.25-1.302.175-1.427-.075-.125-.275-.199-.575-.35z"/></svg>
            </a>
          </div>
          <p class="text-slate-400 text-sm font-medium">
            &copy; 2026 Muhdan Fyan Syah Sofian.
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      function updateLanguageUI() {
        const currentLang = localStorage.getItem('lang') || 'id';
        const langLabel = document.getElementById('langLabel');
        if (langLabel) langLabel.innerText = currentLang.toUpperCase();
        
        document.querySelectorAll('.lang-text').forEach(el => {
          if (el instanceof HTMLElement) {
            el.innerText = currentLang === 'en' ? (el.dataset.en || el.innerText) : (el.dataset.id || el.innerText);
          }
        });

        // Specific detail page content
        const idC = document.getElementById('contentId'), enC = document.getElementById('contentEn');
        if (idC && enC) {
          idC.classList.toggle('hidden', currentLang === 'en');
          enC.classList.toggle('hidden', currentLang !== 'en');
        }
      }

      function initGlobal() {
        const langToggle = document.getElementById('langToggle');
        if (langToggle) {
          langToggle.addEventListener('click', () => {
            const currentLang = localStorage.getItem('lang') || 'id';
            const newLang = currentLang === 'id' ? 'en' : 'id';
            localStorage.setItem('lang', newLang);
            updateLanguageUI();
          });
        }
        updateLanguageUI();
      }

      initGlobal();
      document.addEventListener('astro:page-load', initGlobal);
    </script>
	</body>
</html>

<style is:global>
	:root {
		--primary: #6366f1;
		--secondary: #a855f7;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
	}
  h1, h2, h3 {
    font-family: 'Outfit', sans-serif;
  }
  
  /* Premium Card Transitions */
  .project-card {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
  }
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
  }
  
  /* Smooth Fade-in for Content */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Custom Selection Color */
  ::selection {
    background: rgba(99, 102, 241, 0.2);
    color: #4f46e5;
  }

  /* Refined Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f8fafc;
  }
  ::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }
</style>
