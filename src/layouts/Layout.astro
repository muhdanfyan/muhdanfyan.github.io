---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
  description?: string;
  image?: string;
}

const { title, description = "Muhdan Fyan | Full Stack Developer Portfolio", image = "/img/screenshots/default.png" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
    <ClientRouter />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="canonical" href={`https://muhdanfyan.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Muhdan Fyan Portfolio" />
    <meta property="og:url" content={`https://muhdanfyan.github.io${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content={Astro.url.pathname.startsWith('/tulisan/') ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io/${image.startsWith('/') ? image.slice(1) : image}`} />
    <meta property="og:image:secure_url" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io/${image.startsWith('/') ? image.slice(1) : image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@muhdanfyan" />
    <meta name="twitter:creator" content="@muhdanfyan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io/${image.startsWith('/') ? image.slice(1) : image}`} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Muhdan Fyan Syah Sofian" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-white text-slate-900 font-sans">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--primary: #6366f1;
		--secondary: #a855f7;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
  h1, h2, h3 {
    font-family: 'Outfit', sans-serif;
  }
</style>
