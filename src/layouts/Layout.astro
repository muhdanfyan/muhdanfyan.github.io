---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
  description?: string;
  image?: string;
}

const { title, description = "Muhdan Fyan | Full Stack Developer Portfolio", image = "/img/screenshots/default.png" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
    <ClientRouter />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="canonical" href={`https://muhdanfyan.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Muhdan Fyan Portfolio" />
    <meta property="og:url" content={`https://muhdanfyan.github.io${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content={Astro.url.pathname.startsWith('/writing/') ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:secure_url" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={image.toLowerCase().endsWith('.png') ? 'image/png' : 'image/jpeg'} />
    <meta property="og:image:alt" content={title} />
    <meta itemprop="image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@muhdanfyan" />
    <meta name="twitter:creator" content="@muhdanfyan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Muhdan Fyan Syah Sofian" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Muhdan Fyan Syah Sofian",
      "url": "https://muhdanfyan.github.io",
      "jobTitle": "Full Stack Developer",
      "knowsAbout": ["Web Development", "PHP", "Laravel", "React", "TypeScript", "AI", "Mobile Development"],
      "sameAs": [
        "https://linkedin.com/in/muhdanfyan",
        "https://github.com/muhdanfyan",
        "https://instagram.com/muhdanfyan"
      ]
    }
    </script>
	</head>
	<body class="bg-white text-slate-900 font-sans">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--primary: #6366f1;
		--secondary: #a855f7;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
	}
  h1, h2, h3 {
    font-family: 'Outfit', sans-serif;
  }
  
  /* Premium Card Transitions */
  .project-card {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
  }
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
  }
  
  /* Smooth Fade-in for Content */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Custom Selection Color */
  ::selection {
    background: rgba(99, 102, 241, 0.2);
    color: #4f46e5;
  }

  /* Refined Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f8fafc;
  }
  ::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }
</style>
