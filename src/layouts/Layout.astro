---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
  description?: string;
  image?: string;
}

const { title, description = "Muhdan Fyan | Full Stack Developer Portfolio", image = "/img/screenshots/default.png" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
    <ClientRouter />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <link rel="canonical" href={`https://muhdanfyan.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Muhdan Fyan Portfolio" />
    <meta property="og:url" content={`https://muhdanfyan.github.io${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content={Astro.url.pathname.startsWith('/writing/') ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:secure_url" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={image.toLowerCase().endsWith('.png') ? 'image/png' : 'image/jpeg'} />
    <meta property="og:image:alt" content={title} />
    <meta itemprop="image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@muhdanfyan" />
    <meta name="twitter:creator" content="@muhdanfyan" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `https://muhdanfyan.github.io${image.startsWith('/') ? image : '/' + image}`} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Muhdan Fyan Syah Sofian" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Muhdan Fyan Syah Sofian",
      "url": "https://muhdanfyan.github.io",
      "jobTitle": "Full Stack Developer",
      "knowsAbout": ["Web Development", "PHP", "Laravel", "React", "TypeScript", "AI", "Mobile Development"],
      "sameAs": [
        "https://linkedin.com/in/muhdanfyan",
        "https://github.com/muhdanfyan",
        "https://instagram.com/muhdanfyan"
      ]
    }
    </script>
	</head>
	<body class="bg-white text-slate-900 font-sans">
    <Navigation />
		<slot />
    <Footer />

    <script is:inline>
      function updateLanguageUI() {
        const currentLang = localStorage.getItem('lang') || 'id';
        const langLabel = document.getElementById('langLabel');
        if (langLabel) {
          langLabel.innerText = currentLang.toUpperCase();
          const langToggle = document.getElementById('langToggle');
          if (langToggle) {
            if (currentLang === 'en') {
              langToggle.classList.add('bg-indigo-600', 'text-white');
              langToggle.classList.remove('bg-slate-100');
            } else {
              langToggle.classList.remove('bg-indigo-600', 'text-white');
              langToggle.classList.add('bg-slate-100');
            }
          }
        }
        
        // Update ALL General Text
        document.querySelectorAll('.lang-text').forEach(el => {
          if (el instanceof HTMLElement) {
            const textID = el.dataset.id;
            const textEN = el.dataset.en;
            const newText = currentLang === 'en' ? textEN : textID;
            
            if (newText) {
              let hasUpdated = false;
              el.childNodes.forEach(node => {
                if (node.nodeType === Node.TEXT_NODE && node.textContent.trim() !== '') {
                  node.textContent = node.textContent.startsWith(' ') ? ' ' + newText : newText;
                  hasUpdated = true;
                }
              });
              if (!hasUpdated && el.children.length === 0) {
                el.innerText = newText;
              }
            }
          }
        });

        // Update Content Blocks (for [slug].astro)
        const idContent = document.getElementById('contentId');
        const enContent = document.getElementById('contentEn');
        if (idContent && enContent) {
          idContent.classList.toggle('hidden', currentLang === 'en');
          enContent.classList.toggle('hidden', currentLang !== 'en');
        }

        // Update Projects Visibility & Text
        document.querySelectorAll('.project-card').forEach(card => {
          if (card instanceof HTMLElement) {
            const langs = JSON.parse(card.dataset.langs || '["id", "en"]');
            card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
            const titleEl = card.querySelector('.project-title');
            const descEl = card.querySelector('.project-desc');
            if (titleEl instanceof HTMLElement) titleEl.innerText = currentLang === 'en' ? (titleEl.dataset.en || titleEl.innerText) : (titleEl.dataset.id || titleEl.innerText);
            if (descEl instanceof HTMLElement) descEl.innerText = currentLang === 'en' ? (descEl.dataset.en || descEl.innerText) : (descEl.dataset.id || descEl.innerText);
          }
        });

        // Update Writings Visibility & Text
        document.querySelectorAll('.writing-card').forEach(card => {
          if (card instanceof HTMLElement) {
            const langs = JSON.parse(card.dataset.langs || '["id", "en"]');
            card.style.display = langs.includes(currentLang) ? 'flex' : 'none';
            const titleEl = card.querySelector('.writing-title');
            const descEl = card.querySelector('.writing-desc');
            if (titleEl instanceof HTMLElement) titleEl.innerText = currentLang === 'en' ? (titleEl.dataset.en || titleEl.innerText) : (titleEl.dataset.id || titleEl.innerText);
            if (descEl instanceof HTMLElement) descEl.innerText = currentLang === 'en' ? (descEl.dataset.en || descEl.innerText) : (descEl.dataset.id || descEl.innerText);
          }
        });
      }

      function initGlobal() {
        if (!localStorage.getItem('lang')) {
          try {
            const userLang = navigator.language || '';
            const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
            const isIndonesianTZ = timezone.includes('Jakarta') || timezone.includes('Makassar') || timezone.includes('Jayapura') || timezone.includes('Pontianak');
            const isIndonesianLang = userLang.toLowerCase().startsWith('id');
            localStorage.setItem('lang', (isIndonesianTZ || isIndonesianLang) ? 'id' : 'en');
          } catch (e) {
            localStorage.setItem('lang', 'id');
          }
        }
        
        updateLanguageUI();

        const langToggle = document.getElementById('langToggle');
        if (langToggle) {
          const newLangToggle = langToggle.cloneNode(true);
          langToggle.parentNode.replaceChild(newLangToggle, langToggle);
          newLangToggle.addEventListener('click', () => {
            const currentLang = localStorage.getItem('lang') || 'id';
            const newLang = currentLang === 'id' ? 'en' : 'id';
            localStorage.setItem('lang', newLang);
            updateLanguageUI();
            // Dispatch event for components that might need to react (like audio player)
            window.dispatchEvent(new CustomEvent('lang-changed', { detail: { lang: newLang } }));
          });
        }
      }

      initGlobal();
      document.addEventListener('astro:page-load', initGlobal);
    </script>
	</body>
</html>

<style is:global>
	:root {
		--primary: #6366f1;
		--secondary: #a855f7;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
	}
  h1, h2, h3 {
    font-family: 'Outfit', sans-serif;
  }
  
  /* Premium Card Transitions */
  .project-card {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
  }
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
  }
  
  /* Smooth Fade-in for Content */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Custom Selection Color */
  ::selection {
    background: rgba(99, 102, 241, 0.2);
    color: #4f46e5;
  }

  /* Refined Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f8fafc;
  }
  ::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }
</style>
